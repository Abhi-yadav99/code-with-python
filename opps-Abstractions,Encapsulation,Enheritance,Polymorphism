child class

class GraduateStudent(Student):
    def __init__(self,name,grade,percentage,stream):   # old parameters from parent class & new parameters  in child class
        super().__init__(name,grade,percentage,stream)  #call parent class init
        self.stream = stream  # new attributes in child class
        
    def student_details(self):
        super().student_details()    # methode is inherit from parent class
        print(f'stream is {self.stream}')

gra_Student1 = GraduateStudent("keshav",12,96,'PCM')
print(gra_Student1.stream)

gra_Student1.student_details()



#Polymorphism

class GraduateStudent(Student):
    def __init__(self,name,grade,percentage,stream):   # old parameters from parent class & new parameters  in child class
        super().__init__(name,grade,percentage,stream)  #call parent class init
        self.stream = stream  # new attributes in child class
        
    def student_details(self):
        print(f'{self.name} is in class {self.grade}, with {self.percentage}% from stream is {self.stream}')


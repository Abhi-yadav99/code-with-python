class Student:  #class
    def __init__(self,name,grade,percentage,team):   #methode
        self.name = name
        self.grade = grade
        self.percentage = percentage
        self.team = team
    def student_details(self):   #methode
        print(f"{self.name} is in {self.grade} with {self.percentage}% from {self.team}")
team1 = "A"
team2 = "B"

student1 = Student("Abhi",10,90,team1)  #object
student2 = Student("Akash",9,92,team2)  #object
print(student1.name)
student1.student_details()
